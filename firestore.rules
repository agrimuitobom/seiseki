rules_version = '2';

// 未成年データ保護: ログイン必須＋「自分のデータしか読み書きできない」を基本とする。
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // 既存ドキュメントの所有者が本人か（read / update / delete 用）
    function ownsExisting() {
      return isSignedIn() && resource.data.owner == request.auth.uid;
    }

    // 新規/更新後のドキュメントの所有者が本人か（create / update 用）
    function ownsIncoming() {
      return isSignedIn() && request.resource.data.owner == request.auth.uid;
    }

    // プロフィール: 本人のみ
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // ユーザーごとの学習データ（owner フィールドで本人に限定）
    match /testResults/{docId} {
      allow read, delete: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
    }

    match /studyLogs/{docId} {
      allow read, delete: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
    }

    match /assignments/{docId} {
      allow read, delete: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
    }

    match /wrongAnswers/{docId} {
      allow read, delete: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
    }

    // 授業プリント・資料（科目ごと）のメタデータ
    match /materials/{docId} {
      allow read, delete: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
    }

    // AI生成の模擬問題。作成は Cloud Function（管理者権限）が行うため、
    // クライアントには読み取りと削除のみ本人に許可する。
    match /quizzes/{docId} {
      allow read, delete: if ownsExisting();
    }

    // フレンド: 申請者か被申請者のみが読み書きできる
    match /friendships/{docId} {
      allow read, write: if isSignedIn()
        && (request.auth.uid == resource.data.requester
            || request.auth.uid == resource.data.addressee
            || request.auth.uid == request.resource.data.requester
            || request.auth.uid == request.resource.data.addressee);
    }

    // 公開プロフィール（表示名・フレンドコード・週間勉強時間）
    // ランキング表示のため、ログインユーザーは個別取得(get)できる。
    // 一覧(list)は禁止して列挙を防ぐ。書き込みは本人のみ。
    match /publicProfiles/{uid} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create, update: if isSignedIn() && request.auth.uid == uid;
    }

    // フレンドコード → uid の対応表（コード検索用）
    match /friendCodes/{code} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }

    // 既定では全拒否（上記以外のパスはアクセス不可）
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
